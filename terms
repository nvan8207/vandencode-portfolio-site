    /* NAV */
    nav{position:fixed;top:0;left:0;right:0;z-index:600;height:var(--nav-h);display:flex;align-items:center;justify-content:space-between;padding:0 var(--gut);border-bottom:1px solid var(--border);background:rgba(17,11,17,.92);backdrop-filter:blur(14px)}
    .nav-logo{font-family:var(--ff-d);font-size:1.65rem;letter-spacing:.06em;color:var(--acid)}
    .nav-links{display:flex;gap:1.8rem;align-items:center}
    .nav-links a{font-size:.65rem;letter-spacing:.18em;text-transform:uppercase;color:var(--dim);transition:color .2s}
    .nav-links a:hover{color:var(--acid)}
    .nav-links a.nav-special{color:var(--sage);border:1px solid var(--forest);padding:.28rem .85rem}
    .nav-links a.nav-special:hover{background:var(--forest);color:var(--acid)}
    .hamburger{display:none;flex-direction:column;justify-content:center;gap:5px;width:36px;height:36px;background:none;border:none;cursor:none;padding:4px}
    .hamburger span{display:block;height:1.5px;background:var(--acid);transition:transform .3s,opacity .3s,width .3s;transform-origin:center}
    .hamburger.open span:nth-child(1){transform:translateY(6.5px) rotate(45deg)}
    .hamburger.open span:nth-child(2){opacity:0;width:0}
    .hamburger.open span:nth-child(3){transform:translateY(-6.5px) rotate(-45deg)}
    .nav-drawer{position:fixed;top:var(--nav-h);left:0;right:0;z-index:599;background:rgba(17,11,17,.97);backdrop-filter:blur(18px);border-bottom:1px solid var(--border);display:flex;flex-direction:column;padding:0 var(--gut);max-height:0;overflow:hidden;transition:max-height .35s cubic-bezier(.4,0,.2,1),padding .35s}
