    footer{border-top:1px solid var(--border);padding:1.75rem var(--gut);display:flex;align-items:center;justify-content:space-between;font-size:.65rem;color:var(--muted);letter-spacing:.1em}
    .fl{display:flex;gap:1.5rem}
    .fl a{color:var(--muted);transition:color .2s}
    .fl a:hover{color:var(--acid)}
    .fdot{color:var(--blush);margin:0 .3rem}

